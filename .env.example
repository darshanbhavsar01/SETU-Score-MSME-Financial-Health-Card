# SETU Score — environment template. Copy to `.env` (git-ignored) and fill as needed.
# The default POC path needs NONE of these; all data, scoring, and ML run locally.

# --- Optional Gemini narrative polish (§8). Off by default; templates are the default path. ---
ENABLE_LLM_NARRATIVE=false
# AI Studio (free-tier) key. Only read when ENABLE_LLM_NARRATIVE=true. Never commit a real key.
GEMINI_API_KEY=
# Optional second AI Studio account/key, tried only once the primary is exhausted
# across every model in the cascade (backend/app/config.py GEMINI_MODEL_CASCADE).
GEMINI_API_KEY_FALLBACK=
# Override the model cascade (comma-separated, tried in order). Leave unset for the
# built-in default list (flash 3 -> 2.5 -> 2.0 -> 1.5 family, newest first).
# GEMINI_MODELS=gemini-flash-latest,gemini-2.5-flash,gemini-2.0-flash

# --- Cloud Run deploy (§13). Only used by `make deploy`, not by the app at runtime. ---
GCP_PROJECT_ID=
GCP_REGION=asia-south1
